<UserControl x:Class="Evently.Client.Wpf.Features.Events.EventDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Evently.Client.Wpf.Features.Events"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Back button -->
        <Button Content="← Powrót do listy"
                HorizontalAlignment="Left" Margin="0,0,0,16"
                Padding="12,6" Background="Transparent"
                Foreground="#4A90D9"
                BorderThickness="0" Cursor="Hand"
                Click="BackButton_Click" />

        <!-- Loading -->
        <TextBlock Grid.Row="1" Text="Ładowanie..."
                   FontSize="16"
                   Visibility="{Binding Model.IsLoading,
  Converter={StaticResource BoolToVisibility}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <!-- Error -->
        <Border Grid.Row="1" Background="#FFF0F0"
                CornerRadius="8" Padding="16"
                Visibility="{Binding Model.Error,
  Converter={StaticResource NullToCollapsed}}"
                VerticalAlignment="Top">
            <TextBlock Text="{Binding Model.Error}"
                       Foreground="#D32F2F" FontSize="14" />
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1"
              Visibility="{Binding Model.Event,
  Converter={StaticResource NullToCollapsed}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Event info -->
            <StackPanel Margin="0,0,24,0">
                <TextBlock Text="{Binding Model.Event.Title}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#1A1A2E"
                           TextWrapping="Wrap" />

                <Border Background="#E8F5E9" CornerRadius="4"
                        Padding="8,4" Margin="0,8,0,0"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding
  Model.Event.Status}" Foreground="#2E7D32" FontSize="12" />
                </Border>

                <StackPanel Margin="0,16,0,0">
                    <TextBlock FontSize="14"
                               Foreground="#666">
                        <Run Text="📍 " /> <Run Text="{Binding
  Model.Event.Location}" />
                    </TextBlock>
                    <TextBlock FontSize="14" Foreground="#666"
                               Margin="0,4,0,0">
                        <Run Text="📅 " />
                        <Run Text="{Binding
  Model.Event.StartsAtUtc, StringFormat='{}{0:dd.MM.yyyy
  HH:mm}'}" />
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="{Binding
  Model.Event.Description}" FontSize="14"
                           Foreground="#333"
                           TextWrapping="Wrap" Margin="0,16,0,0" />
            </StackPanel>

            <!-- Right: Ticket types -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Bilety" FontSize="20"
                           FontWeight="SemiBold" Margin="0,0,0,12" />

                <ItemsControl ItemsSource="{Binding
  Model.Event.TicketTypes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F5F5F5"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding
  Name}" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel
                                        Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock
                                            Text="{Binding Price, StringFormat='{}{0:F2}'}"

                                            FontSize="18" FontWeight="Bold" Foreground="#4A90D9" />
                                        <TextBlock
                                            Text="{Binding Currency}" FontSize="14"

                                            Foreground="#666" Margin="4,4,0,0" />
                                    </StackPanel>
                                    <TextBlock
                                        Foreground="#888" FontSize="12" Margin="0,4,0,0">
                                        <Run Text="Dostępne:
  " /><Run Text="{Binding Quantity}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>