<UserControl x:Class="Evently.Client.Wpf.Features.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Evently.Client.Wpf.Features.Login"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
        <Border Background="White" CornerRadius="12" Padding="32">
            <StackPanel>
                <TextBlock Text="Evently" FontSize="32" FontWeight="Bold" Foreground="#1A1A2E"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Log into the system" FontSize="14" Foreground="#666" HorizontalAlignment="Center"
                           Margin="0,0,0,24" />

                <Border Background="#FFF0F0" CornerRadius="6" Padding="12" Margin="0,0,0,16"
                        Visibility="{Binding Model.Error, Converter={StaticResource NullToCollapsed}}">
                    <TextBlock Text="{Binding Model.Error}" Foreground="#D32F2F" FontSize="13"/>
                </Border>
                <TextBlock Text="Email" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Model.Email, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10" FontSize="14" Margin="0,0,0,16"
                         TextChanged="Email_TextChanged"/>
                <TextBlock Text="Password" FontSize="13" Foreground="#333" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Padding="10" FontSize="14" Margin="0,0,0,24"
                             PasswordChanged="Password_PasswordChanged"/>
                <Button Content="Sign in" Padding="12" FontSize="16" FontWeight="SemiBold"
                        Background="#4A90D9" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Submit_Click"
                        IsEnabled="{Binding Model.IsLoading, Converter={StaticResource InvertBool}}"/>

                <TextBlock Text="Singing..." FontSize="13" Foreground="#666"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           Visibility="{Binding Model.IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>